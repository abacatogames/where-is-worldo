{
  "extends": ["config:base"],
  "automerge": false,
  "timezone": "Europe/London",
  "schedule": ["* 0-3 1 * *"],
  "dependencyDashboard": true,
  "packageRules": [
    {
      "matchManagers": ["gradle"],
      "groupName": "gradle dependencies"
    },
    {
      "matchDatasources": ["docker"],
      "groupName": "docker base images"
    }
  ],
  "prHourlyLimit": 2,
  "prConcurrentLimit": 5,
  "labels": ["dependencies", "renovate"]
}
